# ══════════════════════════════════════════════════════════════
# NRFRP — Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ══════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ── Database ───────────────────────────────────────────────────
DB_PASSWORD=CHANGE_THIS_STRONG_DB_PASSWORD_123!

# ── Security ───────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_64_CHAR_HEX_STRING_GENERATED_ABOVE

# ── AWS ────────────────────────────────────────────────────────
# From: AWS Console → IAM → Users → Security credentials → Create access key
AWS_ACCESS_KEY_ID=AKIA_YOUR_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_HERE
AWS_REGION=ap-south-1

# S3 bucket (create a PRIVATE bucket in ap-south-1)
S3_BUCKET=nrfrp-docs-prod

# SNS for SMS OTP (in production; dev uses console.log)
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:YOUR_ACCOUNT_ID:nrfrp-sms

# ── Payment ────────────────────────────────────────────────────
# From: razorpay.com → Settings → API Keys → Generate Test/Live Key
RAZORPAY_KEY_ID=rzp_live_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET

# ── Email ──────────────────────────────────────────────────────
# Verify your email in AWS SES first
SES_FROM_EMAIL=noreply@yourdomain.com
